#include <iostream>
using namespace std;

const long long MOD = 1000000007LL;

long long mod_pow(long long a, long long e) {
    long long res = 1;
    a %= MOD;
    while (e > 0) {
        if (e & 1) res = res * a % MOD;
        a = a * a % MOD;
        e >>= 1;
    }
    return res;
}

int main() {
    ios::sync_with_stdio(false);
    cin.tie(nullptr);

    int T;
    cin >> T;
    while (T--) {
        long long b1, q, n;
        cin >> b1 >> q >> n;

        if (n == 0 || b1 == 0) {
            cout << 0 << '\n';
            continue;
        }
        if (q == 0) {
            cout << (b1 % MOD) << '\n';
            continue;
        }
        if (q == 1) {
            cout << (b1 % MOD) * (n % MOD) % MOD << '\n';
            continue;
        }

        long long pow_q = mod_pow(q, n);
        long long numer = (pow_q - 1 + MOD) % MOD;
        long long den_inv = mod_pow((q - 1 + MOD) % MOD, MOD - 2);
        long long ans = (b1 % MOD) * numer % MOD * den_inv % MOD;
        cout << ans << '\n';
    }
    return 0;
}
