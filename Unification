#include <iostream>
#include <queue>
#include <vector>
#include <functional>
using namespace std;

int main() {
    ios::sync_with_stdio(false);
    cin.tie(nullptr);

    int N;
    cin >> N;
    priority_queue<long long, vector<long long>, greater<long long>> pq;
    for (int i = 0; i < N; ++i) {
        long long x;
        cin >> x;
        pq.push(x);
    }

    for (int step = 0; step < N - 1; ++step) {
        long long a = pq.top(); pq.pop();
        long long b = pq.top(); pq.pop();
        if (a > b) swap(a, b);
        cout << a << ' ' << b << '\n';
        pq.push(a + b);
    }
    return 0;
}
